<UserControl x:Class="Diseño_Proyecto.View.Inventario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diseño_Proyecto.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Panel de Control"
                        FontSize="18"
                        FontWeight="Bold"/>
                <TextBlock Text="Gestión básica de productos y stock"
                        FontSize="12"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition Width="326.667"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Productos" Margin="5">
                <TextBlock Text=""
                        FontSize="20"
                        HorizontalAlignment="Center"/>
            </GroupBox>

            <GroupBox Header="Stock Bajo" Grid.Column="1" Margin="5">
                <TextBlock Text=""
                        FontSize="20"
                        HorizontalAlignment="Center"/>
            </GroupBox>

            <GroupBox Header="Valor Inventario" Grid.Column="2" Margin="5">
                <TextBlock Text=""
                        FontSize="20"
                        HorizontalAlignment="Center"/>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Producto" Margin="5">
                <StackPanel Margin="10">

                    <TextBlock Text="Código"/>
                    <TextBox Height="25" Margin="0,0,0,8"/>

                    <TextBlock Text="Nombre"/>
                    <TextBox Height="25" Margin="0,0,0,8"/>

                    <TextBlock Text="Categoría"/>
                    <ComboBox Height="25" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Text="Cantidad"/>
                            <TextBox Height="25"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Precio"/>
                            <TextBox Height="25"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Stock mínimo"/>
                    <TextBox Height="25" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Agregar" Width="70" Margin="5"/>
                        <Button Content="Actualizar" Width="80" Margin="5"/>
                        <Button Content="Eliminar" Width="70" Margin="5"/>
                    </StackPanel>

                    <Button Content="Limpiar"
                         Width="100"
                         Margin="5"
                         HorizontalAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Listado" Grid.Column="1" Margin="5">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                           AutoGenerateColumns="False"
                           IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Width="*"/>
                            <DataGridTextColumn Header="Nombre" Width="*"/>
                            <DataGridTextColumn Header="Categoría" Width="*"/>
                            <DataGridTextColumn Header="Cantidad" Width="*"/>
                            <DataGridTextColumn Header="Precio" Width="*"/>
                            <DataGridTextColumn Header="Mínimo" Width="*"/>
                            <DataGridTextColumn Header="Total" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </GroupBox>

        </Grid>
    </Grid>
</UserControl>
