<Window x:Class="Diseño_Proyecto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Diseño_Proyecto"
        xmlns:vm="clr-namespace:Diseño_Proyecto.View"
        xmlns:ctr="clr-namespace:Diseño_Proyecto.Controls"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F1F1F1" Padding="8">
            <ctr:menu></ctr:menu>
        </Border>
        
        
    </Grid>
    
</Window>
